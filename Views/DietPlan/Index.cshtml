@using Microsoft.AspNetCore.Html
@using ManvarFitness.Entity
@model ManvarFitness.Models.DietPlanModel

@{
    ViewData["Title"] = Model.Concern == null
        ? "Diet Plan"
        : "Diet Plan Details - " + Model.Concern.Name;

    var alldays = new List<string> { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday" };

    Func<List<string>, IHtmlContent> RenderList = items =>
    {
        var ul = "<ol>";
        if (items != null && items.Any())
        {
            foreach (var item in items)
                ul += $"<li>{item}</li>";
        }
        else
        {
            ul += "<li></li>";
        }
        ul += "</ol>";
        return Html.Raw(ul);
    };
}

<style>
    .table th {
        vertical-align: text-top;
        padding: 18px;
        text-align: center;
    }

    .table td {
        vertical-align: top;
        text-align: left;
    }

    .diet-table {
        min-width: 350px;
        overflow-x: auto;
    }

    .diet-table th,
    .diet-table td {
        min-width: 200px;
    }

    tr.selected {
        background-color: white !important; 
    }

</style>

@Html.AntiForgeryToken()

<form method="get" asp-action="Index" class="mb-3">
    <!-- Main Concern -->
    <label for="concernSelect" class="form-label">Select Concern:</label>
    <select id="concernSelect" name="concernId" class="form-select w-50" onchange="this.form.submit()">
        <option value="">-- Select Concern --</option>
        @foreach (var c in ViewBag.ConcernsList)
        {
            if (Model.ConcernId == c.ConcernId)
            {
                <option value="@c.ConcernId" selected>@c.Name</option>
            }
            else
            {
                <option value="@c.ConcernId">@c.Name</option>
            }
        }
    </select>

    <!-- Sub-Concern: show only if there are sub-concerns -->
    @if (ViewBag.SubConcernsList != null && ((List<SubConcerns>)ViewBag.SubConcernsList).Any())
    {
        <div class="mt-3">
            <label for="subconcernSelect" class="form-label">Select Sub Concern:</label>
            <select id="subconcernSelect" name="subconcernId" class="form-select w-50" onchange="this.form.submit()">
                <option value="">-- Select Sub Concern --</option>
                @foreach (var sc in (List<SubConcerns>)ViewBag.SubConcernsList)
                {
                    if (Model.SubConcernId == sc.SubConcernId)
                    {
                        <option value="@sc.SubConcernId" selected>@sc.Name</option>
                    }
                    else
                    {
                        <option value="@sc.SubConcernId">@sc.Name</option>
                    }
                }
            </select>
        </div>
    }
</form>

<h2>@ViewData["Title"]</h2>

<div style="overflow-x: auto;">
    <table class="table table-bordered diet-table">
        <thead class="table-light">
            <tr>
                <th>Day</th>
                <th>Empty Stomach</th>
                <th>Early Morning Snack</th>
                <th>Exercise</th>
                <th>Breakfast</th>
                <th>Mid Morning Snack</th>
                <th>Lunch</th>
                <th>Evening Snack</th>
                <th>Dinner</th>
                <th>Bedtime</th>
            </tr>
        </thead>
        <tbody id="diet-body">
            @for (int i = 0; i < Model.Days.Count; i++)
            {
                var day = Model.Days[i];
                if (string.IsNullOrEmpty(day.DayName))
                {
                    day.DayName = alldays[i % alldays.Count]; // default day
                }
                <tr>
                    <td>
                        <select class="day-dropdown">
                            <option value="">Select Day</option>
                            @foreach(var d in alldays)
                            {
                                if (d == day.DayName)
                                {
                                    <option value="@d" selected>@d</option>
                                }
                                else
                                {
                                    <option value="@d">@d</option>
                                }
                            }
                        </select>
                    </td>
                    <td contenteditable="true">@RenderList(day.EmptyStomach)</td>
                    <td contenteditable="true">@RenderList(day.EarlyMorningSnack)</td>
                    <td contenteditable="true">@RenderList(day.Exercise)</td>
                    <td contenteditable="true">@RenderList(day.Breakfast)</td>
                    <td contenteditable="true">@RenderList(day.MidMorningSnack)</td>
                    <td contenteditable="true">@RenderList(day.Lunch)</td>
                    <td contenteditable="true">@RenderList(day.EveningSnack)</td>
                    <td contenteditable="true">@RenderList(day.Dinner)</td>
                    <td contenteditable="true">@RenderList(day.Bedtime)</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<br />

<button type="button" id="row-add" class="btn btn-success btn-sm px-4">Replicate</button>
<button type="button" id="savediet" class="btn btn-success btn-sm px-4">Save</button>
<a class="btn btn-secondary btn-sm px-4" asp-action="Index" asp-controller="DietPlan">Back</a>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const tableBody = document.getElementById("diet-body");
        let selectedRow = null;
        const alldays = ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"];

        // ROW SELECTION
        tableBody.addEventListener("click", function (e) {
            const row = e.target.closest("tr");
            if (!row) return;
            if (selectedRow) selectedRow.classList.remove("selected");
            row.classList.add("selected");
            selectedRow = row;
        });

        // GET USED DAYS EXCEPT CURRENT ROW
        function getUsedDays(exceptRow) {
            const used = [];
            document.querySelectorAll("#diet-body tr").forEach(row => {
                if (row === exceptRow) return;
                const select = row.querySelector(".day-dropdown");
                if (select && select.value) used.push(select.value);
            });
            return used;
        }

        // POPULATE DROPDOWN
        function populateDropdown(dropdown, currentValue) {
            const usedDays = getUsedDays(dropdown.closest("tr"));
            dropdown.innerHTML = '<option value="">Select Day</option>';
            alldays.forEach(day => {
                if (!usedDays.includes(day) || day === currentValue) {
                    const option = document.createElement("option");
                    option.value = day;
                    option.text = day;
                    if(day === currentValue) option.selected = true;
                    dropdown.appendChild(option);
                }
            });
        }

        // INITIALIZE DROPDOWNS
        document.querySelectorAll(".day-dropdown").forEach(dd => populateDropdown(dd, dd.value));

        // FUNCTION TO REORDER ROWS IN DOM
        function reorderRows() {
            const rows = Array.from(document.querySelectorAll("#diet-body tr"));
            const rowsByDay = {};
            rows.forEach(r => {
                const day = r.querySelector(".day-dropdown").value;
                if (day) rowsByDay[day] = r;
            });
            alldays.forEach(day => {
                if (rowsByDay[day]) tableBody.appendChild(rowsByDay[day]);
            });
        }

        // REPLICATE ROW
        document.getElementById("row-add").addEventListener("click", function() {
            if (!selectedRow) { alert("Select a row to replicate!"); return; }

            const newRow = selectedRow.cloneNode(true);
            newRow.classList.remove("selected");

            const daySelect = newRow.querySelector(".day-dropdown");
            if(daySelect) {
                const currentValue = daySelect.value;
                const usedDays = Array.from(document.querySelectorAll("#diet-body .day-dropdown"))
                                      .filter(dd => dd !== daySelect)
                                      .map(dd => dd.value)
                                      .filter(v => v);

                // Assign original day if free, else next available day in order
                const assignedDay = currentValue && !usedDays.includes(currentValue)
                                    ? currentValue
                                    : alldays.find(d => !usedDays.includes(d)) || "";

                populateDropdown(daySelect, assignedDay);
            }

            // Insert after selected row
            selectedRow.parentNode.insertBefore(newRow, selectedRow.nextSibling);

            selectedRow.classList.remove("selected");
            selectedRow = null;

            // Reorder rows to maintain Monday → Sunday
            reorderRows();

            newRow.scrollIntoView({ behavior:"smooth", block:"center" });
        });

        // SAVE DIET PLAN
        document.getElementById("savediet").addEventListener("click", function() {
            const concernId = document.getElementById("concernSelect").value;
            if(!concernId) { alert("Select concern first."); return; }

            const subSelect = document.getElementById("subconcernSelect");
            const subConcernId = subSelect ? parseInt(subSelect.value) : 0;

            const rows = document.querySelectorAll("#diet-body tr");
            const dietPlan = {
                Name: "@Model.Name",
                ConcernId: parseInt(concernId),
                SubConcernId: subConcernId,
                Days: []
            };

            rows.forEach(row => {
                const dayDropdown = row.querySelector(".day-dropdown");
                const dayName = dayDropdown ? dayDropdown.value : "";
                if(!dayName) return;

                const getCellData = idx => {
                    const cell = row.cells[idx];
                    const lis = cell.querySelectorAll("li");
                    if(lis.length > 0) return Array.from(lis).map(li => li.innerText.trim()).filter(t => t);
                    const text = cell.innerText.trim();
                    return text ? [text] : [];
                };

                dietPlan.Days.push({
                    DayName: dayName,
                    EmptyStomach: getCellData(1),
                    EarlyMorningSnack: getCellData(2),
                    Exercise: getCellData(3),
                    Breakfast: getCellData(4),
                    MidMorningSnack: getCellData(5),
                    Lunch: getCellData(6),
                    EveningSnack: getCellData(7),
                    Dinner: getCellData(8),
                    Bedtime: getCellData(9),
                    IsActive: true
                });
            });

            if(dietPlan.Days.length === 0) { alert("No valid day selected to save."); return; }

            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            fetch('/DietPlan/SaveDietPlan', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify(dietPlan)
            })
            .then(res => res.json())
            .then(data => {
                if(data.success) {
                    alert("Diet plan saved!");
                    location.reload();
                } else {
                    alert("Failed to save diet plan!");
                    console.error(data);
                }
            })
            .catch(err => console.error(err));
        });

    });
</script>