@model dynamic

<h1 class="mb-4">Customer Details</h1>

<div class="card mb-4 shadow-sm">
    <div class="card-body">
        <h5 class="card-title">User ID: @Model.UserId</h5>

        <p class="card-text"><strong>Name:</strong> @(!string.IsNullOrEmpty(Model.Name) ? Model.Name : "Not Updated")</p>
        <p class="card-text"><strong>Email:</strong> @(!string.IsNullOrEmpty(Model.Email) ? Model.Email : "Not Updated")</p>
        <p class="card-text"><strong>Password:</strong> @(!string.IsNullOrEmpty(Model.Password) ? Model.Password : "Not Updated")</p>
        <p class="card-text"><strong>Phone:</strong> @(!string.IsNullOrEmpty(Model.Mobile) ? Model.Mobile : "Not Updated")</p>
        <p class="card-text"><strong>Gender:</strong> @(!string.IsNullOrEmpty(Model.Gender) ? Model.Gender : "Not Updated")</p>

        <a class="btn btn-secondary" href="/Customers/Index">Back</a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <h5 class="card-title mb-3">Related Information</h5>
        <div class="table-responsive">
            <table class="table table-striped table-bordered w-100 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Profile</th>
                        <th>Diet Plan</th>
                        <th>Results</th>
                        <th>Workouts</th>
                        <th>Payments</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>@Model.Profile ?? "No Data"</td>
                        <td>@Model.DietPlan ?? "No Data"</td>
                        <td>@Model.Results ?? "No Data"</td>
                        <td>@Model.Workouts ?? "No Data"</td>
                        <td>@Model.Payments ?? "No Data"</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>