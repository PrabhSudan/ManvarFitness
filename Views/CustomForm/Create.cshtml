@model ManvarFitness.Models.CustomFormModel
<style>
    body {
        background-color: ghostwhite;
    }

    .card {
        background: white;
        border-radius: 12px;
        padding: 1rem;
    }

    .card-body h2 {
        text-align: center;
        font-weight: 700;
        margin-bottom: 1.5rem;
    }

    .form-label {
        min-width: 150px;
        font-weight: 600;
        margin-bottom: 0.25rem;
    }

    .form-group {
        margin-bottom: 0.75rem;
    }

    .field-item {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 6px 0;
        flex-wrap: nowrap;
    }

    .form-control {
        border-radius: 10px;
        padding: 8px 12px;
        background-color: #ffffff;
        border: 1px solid #ced4da;
        min-width: 120px;
        flex: 1 1 auto;
    }

    .form-control:focus {
        border-color: #ced4da;
        box-shadow: 0 0 0 0.1rem rgba(0,0,0,0.08);
    }

    .number-range,
    .text-maxlength,
    .options-box {
        display: flex;
        gap: 4px;
        flex: 2 1 auto;
        align-items: center;
    }

    .number-range input,
    .text-maxlength input,
    .options-box input {
        flex: 1 1 auto;
    }

    .field-item .add-field,
    .field-item .add-option,
    .field-item .remove-field {
        width: 36px;
        height: 36px;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        flex: 0 0 auto;
    }

    .text-danger {
        font-size: 0.875rem;
    }

    .action-row {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 16px;
        margin-top: 1.5rem;
    }

    .action-row .btn {
        width: 120px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        border-radius: 8px;
    }

    .card-body {
        padding: 1rem 1.2rem;
    }

    /* Custom Dropdown */
    .custom-select-wrapper {
        position: relative;
        width: 100%;
        margin-bottom: 10px;
    }

    .custom-select-selected {
        background-color: #fff;
        border: 1px solid #ced4da;
        border-radius: 10px;
        padding: 8px 12px;
        cursor: pointer;
        user-select: none;
    }

    .custom-select-options {
        position: absolute;
        top: 100%;
        left: 0;
        width: 100%;
        background-color: #fff;
        border: 1px solid #ced4da;
        border-radius: 8px;
        max-height: 8rem; /* ~5-7 items */
        overflow-y: auto;
        display: none;
        z-index: 1000;
    }

    .custom-select-options div {
        padding: 8px 12px;
        cursor: pointer;
    }

    .custom-select-options div:hover {
        background-color: #f1f1f1;
    }
</style>

<div class="container mt-4">
    <div class="card shadow-lg border-0">
        <div class="card-body p-4">
            <h2>Create Custom Field</h2>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div class="form-row d-flex gap-3">
                    <!-- Concern -->
                    <div class="form-group flex-fill">
                        <label class="form-label">Select Main Concern</label>
                        <div class="custom-select-wrapper" id="ConcernWrapper">
                            <div class="custom-select-selected">-- Select Concern --</div>
                            <div class="custom-select-options">
                                @foreach(var item in ViewBag.ConcernsList)
                                {
                                    <div data-value="@item.Value">@item.Text</div>
                                }
                            </div>
                            <select asp-for="ConcernId" class="d-none" id="ConcernId">
                                <option value="">-- Select Concern --</option>
                                @foreach(var item in ViewBag.ConcernsList)
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            </select>
                        </div>
                        <span asp-validation-for="ConcernId" class="text-danger"></span>
                    </div>

                    <!-- Sub Concern -->
                    <div class="form-group flex-fill">
                        <label class="form-label">Select Sub Concern</label>
                        <div class="custom-select-wrapper" id="SubConcernWrapper">
                            <div class="custom-select-selected">-- Select Sub Concern --</div>
                            <div class="custom-select-options"></div>
                            <select asp-for="SubConcernId" class="d-none" id="SubConcernId">
                                <option value="">-- Select Sub Concern --</option>
                            </select>
                        </div>
                        <span asp-validation-for="SubConcernId" class="text-danger"></span>
                    </div>
                </div>

                <h5>Fields</h5>
                <div id="fields-container">
                    <div class="field-item mb-2 d-flex align-items-center gap-2">
                        <input name="Fields[0].Label" class="form-control me-2" placeholder="Field Name" required />
                        <select name="Fields[0].FieldType" class="form-control field-type me-2">
                            <option value="">Select FieldType</option>
                            <option value="Text">Textbox</option>
                            <option value="Textarea">Textarea</option>
                            <option value="Date">Date</option>
                            <option value="Number">Number</option>
                            <option value="Select">Dropdown</option>
                            <option value="File">File</option>
                            <option value="Time">Time</option>
                            <option value="Radio">Radio</option>
                            <option value="Checkbox">Checkbox</option>
                        </select>
                        <div class="number-range d-none d-flex gap-2">
                            <input name="Fields[0].MinValue" class="form-control" placeholder="Min" />
                            <input name="Fields[0].MaxValue" class="form-control" placeholder="Max" />
                        </div>
                        <div class="text-maxlength d-none d-flex gap-2">
                            <input name="Fields[0].MaxLength" class="form-control" placeholder="Enter Max Length" />
                        </div>
                        <div class="options-box d-none d-flex gap-2">
                            <input name="Fields[0].Options" class="form-control" placeholder="Enter options" />
                            <button type="button" class="btn btn-success btn-sm add-option">+</button>
                        </div>

                        <div class="file-settings d-none d-flex gap-2">
                            <input name="Fields[0].MaxFileSize"
                                   type="number"
                                   class="form-control"
                                   placeholder="Max MB">
                        </div>

                        <div class="date-settings d-none d-flex gap-2">

                            <input name="Fields[0].MinDate"
                                   type="date"
                                   class="form-control"
                                   placeholder="Date">

                        </div>

                        <div class="time-range d-none d-flex gap-2">
                            <input name="Fields[0].StartTime"
                                   type="time"
                                   class="form-control">

                            <input name="Fields[0].EndTime"
                                   type="time"
                                   class="form-control">
                        </div>
                    </div>
                </div>

                <div class="action-row">
                    <button type="button" class="btn btn-success btn-sm add-field">Add</button>
                    <button type="submit" class="btn btn-primary btn-sm">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    <script>

        // Custom Select Dropdown

                function setupCustomSelect(wrapperId, hiddenSelectId) {
            const wrapper = document.getElementById(wrapperId);
            const selected = wrapper.querySelector('.custom-select-selected');
            const optionsContainer = wrapper.querySelector('.custom-select-options');
            const hiddenSelect = document.getElementById(hiddenSelectId);

            // Toggle dropdown on click
            selected.addEventListener('click', () => {
                optionsContainer.style.display = optionsContainer.style.display === 'block' ? 'none' : 'block';
            });

            // Handle option clicks
            optionsContainer.querySelectorAll('div').forEach(option => {
                option.addEventListener('click', () => {
                    const value = option.dataset.value;
                    const text = option.textContent;

                    // Update hidden select
                    hiddenSelect.value = value;

                    // Update visible text
                    selected.textContent = text;

                    // Close dropdown
                    optionsContainer.style.display = 'none';

                    // Trigger change event if needed (for Sub-Concern load)
                    hiddenSelect.dispatchEvent(new Event('change'));
                });
            });

            // Close dropdown if clicked outside
            document.addEventListener('click', (e) => {
                if (!wrapper.contains(e.target)) {
                    optionsContainer.style.display = 'none';
                }
            });
        }

        setupCustomSelect("ConcernWrapper", "ConcernId");
        setupCustomSelect("SubConcernWrapper", "SubConcernId");

        // Load SubConcerns

        document.getElementById("ConcernId").addEventListener("change", function () {

            const concernId = this.value;

            fetch(`/CustomForm/GetSubConcerns?concernId=${concernId}`)
                .then(res => res.json())
                .then(data => {

                    const subWrapper = document.getElementById("SubConcernWrapper");
                    const optionsContainer = subWrapper.querySelector(".custom-select-options");
                    const hiddenSelect = document.getElementById("SubConcernId");

                    optionsContainer.innerHTML = "";
                    hiddenSelect.innerHTML = '<option value="">-- Select Sub Concern --</option>';

                    data.forEach(item => {

                        const div = document.createElement("div");
                        div.dataset.value = item.subConcernId;
                        div.textContent = item.name;

                        optionsContainer.appendChild(div);

                        const opt = document.createElement("option");
                        opt.value = item.subConcernId;
                        opt.textContent = item.name;

                        hiddenSelect.appendChild(opt);

                    });

                    subWrapper.querySelector(".custom-select-selected").textContent = "-- Select Sub Concern --";
                    hiddenSelect.value = "";

                });

        });

        // Dynamic Fields

        let fieldIndex = 1;

        const fieldsContainer = document.getElementById("fields-container");
        const form = document.querySelector("form");

        fieldsContainer.addEventListener("click", function (e) {

            // Add Option

            if (e.target.classList.contains("add-option")) {

                const parent = e.target.closest(".options-box");

                const wrapper = document.createElement("div");
                wrapper.style.display = "flex";
                wrapper.style.gap = "4px";

                const input = document.createElement("input");
                input.type = "text";
                input.className = "form-control";
                input.placeholder = "Option value";

                const removeBtn = document.createElement("button");
                removeBtn.type = "button";
                removeBtn.className = "btn btn-danger btn-sm remove-option";
                removeBtn.textContent = "-";

                wrapper.appendChild(input);
                wrapper.appendChild(removeBtn);

                parent.insertBefore(wrapper, e.target);
            }

            // Remove Option

            if (e.target.classList.contains("remove-option")) {
                e.target.closest("div").remove();
            }

            // Add Field

            if (e.target.classList.contains("add-field")) {

                const div = document.createElement("div");

                div.classList.add("field-item","mb-3","d-flex","align-items-center","gap-2");

                div.innerHTML = `
                    <input name="Fields[${fieldIndex}].Label"
                           class="form-control"
                           placeholder="Field Name"
                           required />

                    <select name="Fields[${fieldIndex}].FieldType"
                            class="form-control field-type">

                        <option value="">Select FieldType</option>
                        <option value="Text">Textbox</option>
                        <option value="Textarea">Textarea</option>
                        <option value="Date">Date</option>
                        <option value="Number">Number</option>
                        <option value="Select">Dropdown</option>
                        <option value="File">File</option>
                        <option value="Time">Time</option>
                        <option value="Radio">Radio</option>
                        <option value="Checkbox">Checkbox</option>

                    </select>

                    <div class="number-range d-none d-flex gap-2">
                        <input name="Fields[${fieldIndex}].MinValue" class="form-control" placeholder="Min"/>
                        <input name="Fields[${fieldIndex}].MaxValue" class="form-control" placeholder="Max"/>
                    </div>

                    <div class="text-maxlength d-none d-flex gap-2">
                        <input name="Fields[${fieldIndex}].MaxLength" type="number" class="form-control" placeholder="Max Length"/>
                    </div>

                    <div class="options-box d-none d-flex gap-2">
                        <input name="Fields[${fieldIndex}].Options[0]" class="form-control" placeholder="Option value"/>
                        <button type="button" class="btn btn-success btn-sm add-option">+</button>
                    </div>

                    <div class="file-settings d-none d-flex gap-2">

                        <input name="Fields[${fieldIndex}].MaxFileSize"
                               type="number"
                               class="form-control"
                               placeholder="Max MB">
                    </div>

                     <div class="date-settings d-none d-flex gap-2">
                            <input name="Fields[${fieldIndex}].MinDate"
                                    type="date"
                                    class="form-control">

                             <input name="Fields[${fieldIndex}].MaxDate"
                                    type="date"
                                    class="form-control">
                        </div>

                        <div class="time-range d-none d-flex gap-2">
                                    <input name="Fields[${fieldIndex}].StartTime"
                                        type="time"
                                        class="form-control">
                                    <input name="Fields[${fieldIndex}].EndTime"
                                        type="time"
                                        class="form-control">
                        </div>

                    <button type="button" class="btn btn-danger btn-sm remove-field">-</button>
                `;

                fieldsContainer.appendChild(div);

                fieldIndex++;
            }

            // Remove Field

            if (e.target.classList.contains("remove-field")) {
                e.target.closest(".field-item").remove();
                reIndexFields();
            }

        });

        // Field Type Change

        fieldsContainer.addEventListener("change", function (e) {

            if (!e.target.classList.contains("field-type")) return;

            const parent = e.target.closest(".field-item");

            const numberRange = parent.querySelector(".number-range");
            const textMax = parent.querySelector(".text-maxlength");
            const optionsBox = parent.querySelector(".options-box");
            const fileSettings = parent.querySelector(".file-settings");
            const dateSettings = parent.querySelector(".date-settings");
            const timeRange = parent.querySelector(".time-range");

            numberRange?.classList.add("d-none");
            textMax?.classList.add("d-none");
            optionsBox?.classList.add("d-none");
            fileSettings?.classList.add("d-none");
            dateSettings?.classList.add("d-none");
            timeRange?.classList.add("d-none");

            const type = e.target.value;

            if (type === "Number")
                numberRange?.classList.remove("d-none");

            if (type === "Text" || type === "Textarea")
                textMax?.classList.remove("d-none");

            if (["Select","Radio","Checkbox"].includes(type))
                optionsBox?.classList.remove("d-none");

            if (type === "File")
                fileSettings?.classList.remove("d-none");

            if (type === "Date")
                dateSettings?.classList.remove("d-none");

            if (type === "Time")
                timeRange?.classList.remove("d-none");

        });

        // ReIndex Fields

        function reIndexFields(){

            const items = document.querySelectorAll("#fields-container .field-item");

            items.forEach((item,index)=>{

                item.querySelectorAll("input,select").forEach(input=>{

                    if(input.name){
                        input.name = input.name.replace(/Fields\[\d+\]/,`Fields[${index}]`);
                    }

                });

            });

        }

        // Submit Validation

        form.addEventListener("submit",function(e){

            reIndexFields();

            let isValid = true;

            document.querySelectorAll(".field-item").forEach(item=>{

                const type = item.querySelector(".field-type").value;
                const maxLength = item.querySelector(".text-maxlength input");
                const options = item.querySelectorAll(".options-box input");

                if(type==="Text" || type==="Textarea"){
                    if(!maxLength || !maxLength.value){
                        alert("Max Length required");
                        isValid=false;
                    }
                }

                if(["Select","Radio","Checkbox"].includes(type)){
                    if(!options || Array.from(options).every(o=>!o.value.trim())){
                        alert("Options required");
                        isValid=false;
                    }
                }

            });

            if(!isValid) e.preventDefault();

        });

    </script>
}