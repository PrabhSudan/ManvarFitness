@model ManvarFitness.Models.CustomFormModel
<style>
    body {
        background-color: ghostwhite;
    }

    .card {
        background: white;
        border-radius: 12px;
        padding: 1rem;
    }

    .card-body h2 {
        text-align: center;
        font-weight: 700;
        margin-bottom: 1.5rem;
    }

    .form-label {
        min-width: 150px;
        font-weight: 600;
        margin-bottom: 0.25rem;
    }

    .form-group {
        margin-bottom: 0.75rem;
    }

    .field-item {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 6px 0;
        flex-wrap: nowrap;
    }

    .form-control {
        border-radius: 10px;
        padding: 8px 12px;
        background-color: #ffffff;
        border: 1px solid #ced4da;
        min-width: 120px;
        flex: 1 1 auto;
    }

        .form-control:focus {
            border-color: #ced4da;
            box-shadow: 0 0 0 0.1rem rgba(0,0,0,0.08);
        }

    .number-range,
    .text-maxlength,
    .options-box {
        display: flex;
        gap: 4px;
        flex: 2 1 auto;
        align-items: center;
    }

        .number-range input,
        .text-maxlength input,
        .options-box input {
            flex: 1 1 auto;
        }

    .field-item .add-field,
    .field-item .add-option,
    .field-item .remove-field {
        width: 36px;
        height: 36px;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        flex: 0 0 auto;
    }

    .text-danger {
        font-size: 0.875rem;
    }

    .action-row {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 16px;
        margin-top: 1.5rem;
    }

        .action-row .btn {
            width: 120px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            border-radius: 8px;
        }

    .card-body {
        padding: 1rem 1.2rem;
    }

    /* Custom Dropdown */
    .custom-select-wrapper {
        position: relative;
        width: 100%;
        margin-bottom: 10px;
    }

    .custom-select-selected {
        background-color: #fff;
        border: 1px solid #ced4da;
        border-radius: 10px;
        padding: 8px 12px;
        cursor: pointer;
        user-select: none;
    }

    .custom-select-options {
        position: absolute;
        top: 100%;
        left: 0;
        width: 100%;
        background-color: #fff;
        border: 1px solid #ced4da;
        border-radius: 8px;
        max-height: 8rem; /* ~5-7 items */
        overflow-y: auto;
        display: none;
        z-index: 1000;
    }

        .custom-select-options div {
            padding: 8px 12px;
            cursor: pointer;
        }

            .custom-select-options div:hover {
                background-color: #f1f1f1;
            }
</style>

<div class="container mt-4">
    <div class="card shadow p-4">

        <h3 class="text-center mb-4">Create Custom Form</h3>

        <form method="post" id="customForm">
            @Html.AntiForgeryToken()

            <input type="hidden" id="CustomFieldData" name="CustomFieldData" />

            <!-- Concern + SubConcern -->
            <div class="row mb-3">

                <div class="col-md-6">
                    <label>Concern</label>
                    <select asp-for="ConcernId" class="form-control" id="ConcernId">
                        <option value="">-- Select Concern --</option>
                        @foreach (var item in ViewBag.ConcernsList)
                        {
                            <option value="@item.Value">@item.Text</option>
                        }
                    </select>
                </div>

                <div class="col-md-6">
                    <label>Sub Concern</label>
                    <select asp-for="SubConcernId" class="form-control" id="SubConcernId">
                        <option value="">-- Select Sub Concern --</option>
                    </select>
                </div>

            </div>

            <hr />

            <!-- Fields -->
            <h5>Fields</h5>
                <div id="fields-container">
                    <div class="field-item mb-2 d-flex align-items-center gap-2">
                            <input type="text" class="form-control me-2" placeholder="Field Name" required />
                            <select class="form-control field-type">
                                <option value="">Select Type</option>
                                <option value="Text">Textbox</option>
                                <option value="Textarea">Textarea</option>
                                <option value="Date">Date</option>
                                <option value="Number">Number</option>
                                <option value="Select">Dropdown</option>
                                <option value="File">File</option>
                                <option value="Time">Time</option>
                                <option value="Radio">Radio</option>
                                <option value="Checkbox">Checkbox</option>
                            </select>

                            <!-- Dynamic Boxes -->
                            <div class="number-range d-none d-flex gap-2">
                                <input type="number" class="form-control min" placeholder="Min Value" />
                                <input type="number" class="form-control mt-2 max" placeholder="Max Value" />
                            </div>

                            <div class="text-maxlength d-none d-flex gap-2">
                                <input type="number" class="form-control maxlength" placeholder="Max Length" />
                            </div>

                            <div class="options-box d-none d-flex flex-wrap gap-2 align-items-center">

                                <div class="d-flex gap-2 option-row align-items-center">
                                    <input type="text" class="form-control option-input" placeholder="option" />
                                    <button type="button" class="btn btn-success btn-sm add-option">+</button>
                                </div>

                            </div>

                            <div class="file-settings d-none d-flex gap-2">
                                <input type="number" class="form-control maxfilesize" placeholder="Max File Size (MB)" />
                            </div>

                            <div class="date-settings d-none d-flex gap-2">
                                <input type="date" class="form-control" />
                            </div>

                            <div class="time-range d-none d-flex gap-2">
                                <input type="time" class="form-control starttime" />
                                <input type="time" class="form-control endtime mt-2" />
                            </div>
                            
                    </div>

                        <!-- REMOVE BUTTON -->
                        <div class="col-md-2 d-flex align-items-start">
                            <button type="button" class="btn btn-danger remove-field d-none">−</button>
                        </div>

                </div>

       

            <!-- Buttons -->
            <div class="text-center mt-3">
                <button type="button" id="addField" class="btn btn-success">Add Field</button>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>

        </form>

    </div>
</div>

<script>
        const container = document.getElementById("fields-container");


    // --------------------
    // CONCERN → SUBCONCERN
    // --------------------
    document.getElementById("ConcernId").addEventListener("change", function () {

        const subSelect = document.getElementById("SubConcernId");

        fetch(`/CustomForm/GetSubConcerns?concernId=${this.value}`)
            .then(res => res.json())
            .then(data => {

                subSelect.innerHTML = '<option value="">-- Select Sub Concern --</option>';

                if (data.length === 0) {
                    subSelect.disabled = true;
                    return;
                }

                subSelect.disabled = false;

                data.forEach(item => {
                    let opt = document.createElement("option");
                    opt.value = item.subConcernId;
                    opt.textContent = item.name;
                    subSelect.appendChild(opt);
                });

            })
            .catch(() => {
                subSelect.disabled = true;
            });
    });


    // --------------------
    // ADD FIELD
    // --------------------
    document.getElementById("addField").addEventListener("click", function () {

        let first = container.querySelector(".field-item");
        let clone = first.cloneNode(true);

        // reset inputs
        clone.querySelectorAll("input").forEach(i => i.value = "");
        clone.querySelector("select").value = "";

        // clear options
        let optContainer = clone.querySelector(".options-box");
        if (optContainer) {
            let rows = optContainer.querySelectorAll(".option-row");
            rows.forEach((row, index) => {
                if (index === 0) {
                    row.querySelector("input").value = "";
                    row.querySelector(".remove-option")?.remove();
                } else {
                    row.remove();
                }
            });
        }

        // hide all dynamic sections
        clone.querySelectorAll(".number-range, .text-maxlength, .options-box, .file-settings, .date-settings, .time-range")
            .forEach(el => el.classList.add("d-none"));

        // show remove button
        clone.querySelector(".remove-field").classList.remove("d-none");

        container.appendChild(clone);
    });


    // --------------------
    // REMOVE FIELD
    // --------------------
    container.addEventListener("click", function (e) {

        if (e.target.classList.contains("remove-field")) {

            if (container.querySelectorAll(".field-item").length === 1) return;

            e.target.closest(".field-item").remove();
        }
    });


    // --------------------
    // ADD / REMOVE OPTIONS
    // --------------------
        container.addEventListener("click", function (e) {

        if (e.target.classList.contains("add-option")) {

            let box = e.target.closest(".options-box");

            let row = document.createElement("div");
            row.className = "d-flex gap-2 option-row align-items-center";

            row.innerHTML = `
                <input type="text" class="form-control option-input" placeholder="Option" />
                <button type="button" class="btn btn-danger btn-sm remove-option">-</button>
            `;

            box.appendChild(row);
        }

        if (e.target.classList.contains("remove-option")) {
            e.target.closest(".option-row").remove();
        }

    });

    // --------------------
    // FIELD TYPE CHANGE
    // --------------------
    container.addEventListener("change", function (e) {

        if (!e.target.classList.contains("field-type")) return;

        let parent = e.target.closest(".field-item");

        parent.querySelectorAll(".number-range, .text-maxlength, .options-box, .file-settings, .date-settings, .time-range")
            .forEach(el => el.classList.add("d-none"));

        let type = e.target.value;

        if (type === "Number")
            parent.querySelector(".number-range").classList.remove("d-none");

        if (type === "Text" || type === "Textarea")
            parent.querySelector(".text-maxlength").classList.remove("d-none");

        if (["Select", "Radio", "Checkbox"].includes(type)) {

            let optBox = parent.querySelector(".options-box");
            optBox.classList.remove("d-none");

            // ensure at least one option input
            let firstRow = optBox.querySelector(".option-row");

            if (!firstRow) {
                let row = document.createElement("div");
                row.className = "d-flex gap-2 mt-1 option-row";

                row.innerHTML = `
                    <input type="text" class="form-control option-input" placeholder="Enter option" />
                    <button type="button" class="btn btn-success btn-sm add-option">+</button>
                `;

                optBox.appendChild(row);
            }
        }

        if (type === "File")
            parent.querySelector(".file-settings").classList.remove("d-none");

        if (type === "Date")
            parent.querySelector(".date-settings").classList.remove("d-none");

        if (type === "Time")
            parent.querySelector(".time-range").classList.remove("d-none");

    });


    // --------------------
    // SUBMIT → JSON
    // --------------------
        document.getElementById("customForm").addEventListener("submit", function () {

        let fields = [];

        document.querySelectorAll(".field-item").forEach(item => {

            let fieldName = item.querySelector("input[type='text']")?.value || "";
            let fieldType = item.querySelector(".field-type")?.value || "";

            let field = {
                FieldName: fieldName,
                FieldType: fieldType,
                Options: [],
                Min: null,
                Max: null,
                MaxLength: null,
                StartTime: null,
                EndTime: null,
                MaxFileSize: null,
                IsIncluded: false,
                IsRequired: false
            };

            // NUMBER
            if (fieldType === "Number") {
                let minVal = item.querySelector(".min")?.value;
                let maxVal = item.querySelector(".max")?.value;

                field.Min = minVal !== "" ? parseInt(minVal) : null;
                field.Max = maxVal !== "" ? parseInt(maxVal) : null;
            }

            // TEXT
            if (fieldType === "Text" || fieldType === "Textarea") {
                let maxLength = item.querySelector(".maxlength")?.value;

                field.MaxLength = maxLength !== "" ? parseInt(maxLength) : null;
            }

            // OPTIONS
            if (["Select", "Radio", "Checkbox"].includes(fieldType)) {

                item.querySelectorAll(".option-input").forEach(opt => {
                    if (opt.value.trim() !== "") {
                        field.Options.push(opt.value.trim());
                    }
                });

            } else {
                field.Options = null;
            }

            // FILE
            if (fieldType === "File") {
                let fileSize = item.querySelector(".maxfilesize")?.value;
                field.MaxFileSize = fileSize !== "" ? parseInt(fileSize) : null;
            }

            // TIME
            if (fieldType === "Time") {
                field.StartTime = item.querySelector(".starttime")?.value || null;
                field.EndTime = item.querySelector(".endtime")?.value || null;
            }

            fields.push(field);
        });

        document.getElementById("CustomFieldData").value = JSON.stringify(fields);
    });
</script>