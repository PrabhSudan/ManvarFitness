@model IEnumerable<ManvarFitness.Entity.CustomField>
<style>
    /* OFF state */
    .form-check-input {
        background-color: #ccc; /* gray when OFF */
        border-radius: 1rem; /* keep default Bootstrap rounded */
        transition: background-color 0.4s;
    }

        /* ON state */
        .form-check-input:checked {
            background-color: #FF7F11; /* orange when ON */
        }

        .form-check-input:focus {
            outline: none;
            box-shadow: none;
        }

    .customers-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.95rem;
    }

        .customers-table th {
            text-align: center;
            padding: 0.75rem;
            color: black;
            border: 1px solid black;
            background-color: #f8f8f8; /* header white */
        }

        .customers-table td {
            text-align: center;
            padding: 0.6rem;
            border: 1px solid #d1d5db;
            vertical-align: middle;
            background-color: white;
        }

        .customers-table tbody tr {
            background-color: #f9fafb;
        }

</style>
@{
    ViewData["Title"] = "Manage Fields";
}
@Html.AntiForgeryToken()

<div style="text-align: center;">
    <h1 class="fw-semibold mb-3" style="display: inline-block;color: #333;padding-bottom: 6px;border-bottom: 3px solid #FF7F11;border-radius: 0.5px;">
        @ViewData["Title"]
    </h1>
</div>
<!-- Concern Dropdown -->
<form method="get" class="mb-3">
    <div class="input-group" style="max-width: 300px;">
        <select name="concernId" class="form-select" onchange="this.form.submit()">
            <option value="">-- Select Concern --</option>
            @foreach (var concern in ViewBag.Concerns)
            {
                <option value="@concern.ConcernId" selected="@(ViewBag.SelectedConcern == concern.ConcernId)">
                    @concern.Name
                </option>
            }
        </select>
    </div>
</form>

<table class="customers-table">
    <thead>
        <tr>
            <th>FieldName</th>
            <th>Field Type</th>
            <th>Options</th>
            <th>ValidationData</th>
            <th>IsIncluded</th>
            <th>IsRequired</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var field in Model)
        {
            <tr>
                <td>@field.FieldName</td>
                <td>@field.FieldType</td>
                <td>@(string.IsNullOrEmpty(field.Options) ? "-" : field.Options)</td>
                <td>@(string.IsNullOrEmpty(field.ValidationData) ? "-" : field.ValidationData)</td>
                <td class="text-center">
                    <div class="form-check form-switch d-inline-block m-0">
                        <input class="form-check-input toggle-included" type="checkbox"
                               data-id="@field.CustomFieldId"
                               @(field.IsIncluded ? "checked" : "")>
                    </div>
                </td>
                <td class="text-center">
                    <div class="form-check form-switch d-inline-block m-0">
                        <input class="form-check-input toggle-required" type="checkbox"
                               data-id="@field.CustomFieldId"
                               @(field.IsRequired ? "checked" : "")>
                    </div>
                </td>
                <td class="text-center">
                    <button type="button" class="btn btn-sm" style="color:darkorange;"
                            data-bs-toggle="modal"
                            data-bs-target="#deleteModal"
                            data-fieldid="@field.CustomFieldId"
                            data-fieldname="@field.CustomForm">
                        <i class="bi bi-trash-fill fs-5"></i>
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>
<br />
<a asp-action="Create" class="btn btn-success px-4 py-2 fw-semibold">Add New Field</a>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-sm">
            <div class="modal-header bg-light">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete <strong id="fieldNameToDelete"></strong>?</p>
            </div>
            <div class="modal-footer">
                <form id="deleteForm" method="post" asp-controller="CustomForm" asp-action="DeleteField">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="fieldIdInput" name="id" value="" />
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');

            // Toggle Active / Required
            function toggleField(url, checkbox, id) {
                const formData = new URLSearchParams();
                formData.append("__RequestVerificationToken", tokenInput.value);
                formData.append("id", id);

                fetch(url, {
                    method: "POST",
                    headers: { "Content-Type": "application/x-www-form-urlencoded" },
                    body: formData.toString()
                })
                .then(res => res.json())
                .then(data => {
                    if (!data.success) {
                        checkbox.checked = !checkbox.checked;
                        alert("Toggle failed");
                    }
                })
                .catch(() => {
                    checkbox.checked = !checkbox.checked;
                    alert("Error occurred");
                });
            }

            // Apply toggle handlers
            document.querySelectorAll(".toggle-active").forEach(cb => {
                cb.addEventListener("change", function () {
                    toggleField("/CustomForm/ToggleActive", this, this.dataset.id);
                });
            });

            document.querySelectorAll(".toggle-required").forEach(cb => {
                cb.addEventListener("change", function () {
                    toggleField("/CustomForm/ToggleRequired", this, this.dataset.id);
                });
            });
            document.querySelectorAll(".toggle-required").forEach(cb => {
                cb.addEventListener("change", function () {
                    toggleField("/CustomForm/ToggleIncluded", this, this.dataset.id);
                });
            });

            // Delete modal setup
            var deleteModal = document.getElementById('deleteModal');
            var fieldIdToDelete = null;
            var rowToDelete = null;

            deleteModal.addEventListener('show.bs.modal', function (event) {
                var button = event.relatedTarget; // Button that triggered modal
                fieldIdToDelete = button.getAttribute('data-fieldid');
                rowToDelete = button.closest('tr'); // table row to remove
                var fieldName = button.getAttribute('data-fieldname');

                deleteModal.querySelector('#fieldNameToDelete').textContent = fieldName;
                deleteModal.querySelector('#fieldIdInput').value = fieldIdToDelete;
            });

            // AJAX Delete Form Submission
            var deleteForm = document.getElementById('deleteForm');
            deleteForm.addEventListener('submit', function (e) {
                e.preventDefault();

                const id = document.getElementById('fieldIdInput').value;
                const token = deleteForm.querySelector('input[name="__RequestVerificationToken"]').value;

                fetch('/CustomForm/DeleteField', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `id=${id}&__RequestVerificationToken=${token}`
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        // Remove the row from table
                        if (rowToDelete) rowToDelete.remove();

                        // Hide modal
                        const modalInstance = bootstrap.Modal.getInstance(deleteModal);
                        modalInstance.hide();
                    } else {
                        alert('Delete failed.');
                    }
                })
                .catch(() => alert('Error occurred while deleting.'));
            });

        });
    </script>
}