@model ManvarFitness.Entity.AdminUser
@{
}
<h1>User Details</h1>

<div class="card">
    <div class="card-body">
        @* <h5 class="card-title">User ID: @Model.Id</h5> *@

        <p class="card-text">
            <strong>Name:</strong> @Model.Name
        </p>

         <p class="card-text">
            <strong>Email:</strong> @Model.Email
        </p>

        <p class="card-text">
            <strong>Password:</strong> @Model.Password
        </p>

        <p class="card-text">
            <strong>Mobile:</strong> @Model.CountryCode  @Model.Mobile
        </p>

        <a class="btn btn-primary" href="/AdminUser/Index">Back</a>
    </div>
</div>
