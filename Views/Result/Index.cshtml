@model IEnumerable<ManvarFitness.Entity.ResultEntity>
@using System.Text.Json
<style>
    /* OFF state */
    .form-check-input {
        background-color: #ccc; /* gray when OFF */
        border-radius: 1rem; /* keep default Bootstrap rounded */
        transition: background-color 0.4s;
    }

        /* ON state */
        .form-check-input:checked {
            background-color: #FF7F11; /* orange when ON */
        }

        .form-check-input:focus {
            outline: none;
            box-shadow: none;
        }

    .customers-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.95rem;
    }

        .customers-table th {
            text-align: center;
            padding: 0.75rem;
            color: black;
            border: 1px solid black;
            background-color: #f8f8f8; /* header white */
        }

        .customers-table td {
            text-align: center;
            padding: 0.6rem;
            border: 1px solid #d1d5db;
            vertical-align: middle;
            background-color: white;
        }

        .customers-table tbody tr {
            background-color: #f9fafb;
        }

    .center-cell {
        display: flex;
        justify-content: center; /* horizontal */
        align-items: center; /* vertical */
        gap: 4px; /* spacing between buttons/text */
    }

    /* Make carousel arrows BLACK */
    .carousel-control-prev-icon,
    .carousel-control-next-icon {
        filter: invert(1);
    }
</style>

<form id="antiForgeryForm">
    @Html.AntiForgeryToken()
</form>
@{
    ViewData["Title"] = "Results";
}

<div style="text-align: center;">
    <h1 class="fw-semibold mb-2" style="display: inline-block;color: #333;padding-bottom: 6px;border-bottom: 3px solid #FF7F11;border-radius: 0.5px;">
        @ViewData["Title"]
    </h1>
</div>

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mt-2 mb-3">
        <!-- Left: Add New Result button -->
        <a asp-controller="Result"
           asp-action="Create"
           class="btn btn-success px-4 py-2 fw-semibold">
            Add New Result
        </a>

        <!-- Right: Search & Filters -->
        <div class="d-flex align-items-center">
            <div class="input-group">
                <input type="text" id="searchPlan" class="form-control" placeholder="Search User..." />
                <span id="clearSearchBtn"
                      style="position: absolute; right: 50px; top: 35%; transform: translateY(-30%);
                         cursor: pointer; display: none; color: black; font-size: 1.1rem;">&times;</span>
                <button class="btn btn-outline-secondary" type="button" id="searchIconBtn">
                    <i class="bi bi-search"></i>
                </button>
            </div>
        </div>
    </div>
    <!-- TABLE -->
    <div class="customers-table">
        <table>
            <thead>
                <tr>
                    <th style="width:15%">UserName</th>
                    <th class="text-center align-middle" style="width:20%">Mobile</th>
                    <th style="width:20%">Concern</th>
                    <th class="text-center align-middle" style="width:20%">Results</th>
                    <th style="width:10%">Description</th>
                    <th class="text-center align-middle" style="width:15%">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var result in Model)
                {
                    var beforeImages = string.IsNullOrEmpty(result.BeforeImage)
                    ? new List<string>()
                    : JsonSerializer.Deserialize<List<string>>(result.BeforeImage);

                    var afterImages = string.IsNullOrEmpty(result.AfterImage)
                    ? new List<string>()
                    : JsonSerializer.Deserialize<List<string>>(result.AfterImage);

                    var videos = string.IsNullOrEmpty(result.Video)
                    ? new List<string>()
                    : JsonSerializer.Deserialize<List<string>>(result.Video);

                    <tr>
                        <td>
                            @(string.IsNullOrEmpty(result.User?.Name)
                                                    ? "Not Updated"
                                                    : result.User.Name)
                        </td>
                        <td>
                            @if (result.User != null)
                            {
                                <span class="fw-semibold">(@result.User.CountryCode) @result.User.Mobile</span>
                            }
                            else
                            {
                                <span class="text-muted ">Not Assigned</span>
                            }
                        </td>
                        <td>
                            @if (result.SubConcern != null && result.ConcernCategory != null)
                            {
                                <span class="fw-semibold">
                                    (@result.SubConcern.Name) @result.ConcernCategory.Name
                                </span>
                            }
                            else
                            {
                                <span class="text-muted">Not Assigned</span>
                            }
                        </td>

                        <td style="width:240px">

                            @* BEFORE IMAGES *@
                            @if (beforeImages?.Count > 0)
                            {
                                var beforeId = "beforeCarousel_" + result.ResultId;

                                <div class="mb-2">
                                    <small class="fw-bold text-warning">Before</small>

                                    <div id="@beforeId" class="carousel slide">
                                        <div class="carousel-inner">

                                            @for (int i = 0; i < beforeImages.Count; i++)
                                            {
                                                <div class="carousel-item @(i == 0 ? "active" : "") text-center">
                                                    <img src="@beforeImages[i]"
                                                         class="rounded img-fluid"
                                                         style="max-height:150px;">
                                                </div>
                                            }

                                        </div>

                                        @if (beforeImages.Count > 1)
                                        {
                                            <button class="carousel-control-prev"
                                                    type="button"
                                                    data-bs-target="#@beforeId"
                                                    data-bs-slide="prev">
                                                <span class="carousel-control-prev-icon"></span>
                                            </button>

                                            <button class="carousel-control-next"
                                                    type="button"
                                                    data-bs-target="#@beforeId"
                                                    data-bs-slide="next">
                                                <span class="carousel-control-next-icon"></span>
                                            </button>
                                        }
                                    </div>
                                </div>
                            }

                            @* AFTER IMAGES *@
                            @if (afterImages?.Count > 0)
                            {
                                var afterId = "afterCarousel_" + result.ResultId;

                                <div>
                                    <small class="fw-bold text-success">After</small>

                                    <div id="@afterId" class="carousel slide">
                                        <div class="carousel-inner">

                                            @for (int i = 0; i < afterImages.Count; i++)
                                            {
                                                <div class="carousel-item @(i == 0 ? "active" : "") text-center">
                                                    <img src="@afterImages[i]"
                                                         class="rounded img-fluid"
                                                         style="max-height:150px;">
                                                </div>
                                            }

                                        </div>

                                        @if (afterImages.Count > 1)
                                        {
                                            <button class="carousel-control-prev"
                                                    type="button"
                                                    data-bs-target="#@afterId"
                                                    data-bs-slide="prev">
                                                <span class="carousel-control-prev-icon"></span>
                                            </button>

                                            <button class="carousel-control-next"
                                                    type="button"
                                                    data-bs-target="#@afterId"
                                                    data-bs-slide="next">
                                                <span class="carousel-control-next-icon"></span>
                                            </button>
                                        }
                                    </div>
                                </div>
                            }

                            @if ((beforeImages?.Count ?? 0) == 0 &&
                                                    (afterImages?.Count ?? 0) == 0)
                            {
                                <span class="text-muted">No Media</span>
                            }

                        </td>

                        <td>@result.Description</td>
                        <td>
                            <div class="center-cell">

                                <div class="form-check form-switch m-0">
                                    <input class="form-check-input toggle-active" type="checkbox" role="switch"
                                        data-roleid="@result.ResultId"
                                        @(result.IsActive ? "checked" : "") />
                                </div>

                                <a asp-action="Edit" asp-route-id="@result.ResultId" class="btn btn-sm" title="Edit">
                                    <i class="bi bi-pencil-fill text-warning fs-5"></i>
                                </a>

                                <button type="button" class="btn btn-sm" style="color:darkorange;"
                                        data-bs-toggle="modal" data-bs-target="#deleteModal"
                                        onclick="setDeleteId(@result.ResultId)">
                                    <i class="bi bi-trash-fill fs-5"></i>
                                </button>

                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Deletion</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to delete?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    Cancel
                </button>
                <button type="button" class="btn btn-danger" onclick="deleteResult()">
                    Delete
                </button>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        var token = document.querySelector('input[name="__RequestVerificationToken"]').value;

        const searchPlan = document.getElementById("searchPlan");
        const clearSearchBtn = document.getElementById("clearSearchBtn");
        const searchIconBtn = document.getElementById("searchIconBtn");
        const rows = document.querySelectorAll("table tbody tr");

        // ---- SEARCH / FILTER FUNCTION ----
        function filterResults() {
            const searchText = searchPlan.value.toLowerCase().trim();

            rows.forEach(row => {
                const rowText = row.innerText.toLowerCase();
                row.style.display = rowText.includes(searchText) ? "" : "none";
            });
        }

        // ---- SHOW/HIDE CLEAR BUTTON ----
        searchPlan.addEventListener("input", function() {
            clearSearchBtn.style.display = this.value.trim() !== "" ? "inline" : "none";
        });

        // ---- CLEAR SEARCH INPUT ----
        clearSearchBtn.addEventListener("click", function() {
            searchPlan.value = "";
            clearSearchBtn.style.display = "none";
            filterResults();
            searchPlan.focus();
        });

        // ---- SEARCH BUTTON CLICK ----
        if(searchIconBtn){
            searchIconBtn.addEventListener("click", filterResults);
        }

        // ---- ENTER KEY TRIGGERS SEARCH ----
        searchPlan.addEventListener("keydown", function(e){
            if(e.key === "Enter") {
                e.preventDefault();
                filterResults();
            }
        });

        // ---- TOGGLE ACTIVE STATUS ----
        document.querySelectorAll(".toggle-active").forEach(function (toggle) {

            toggle.addEventListener("change", function () {

                var checkbox = this;
                var id = checkbox.getAttribute("data-roleid");

                var token = document.querySelector('input[name="__RequestVerificationToken"]').value;

                fetch("/Result/Toggle?id=" + id, {
                    method: "POST",
                    headers: {
                        "RequestVerificationToken": token
                    }
                })
                .then(response => response.json())
                .then(data => {

                    if (!data.success) {
                        checkbox.checked = !checkbox.checked;
                    }

                })
                .catch(() => {
                    checkbox.checked = !checkbox.checked;
                });

            });

        });

        // ---- DELETE MODAL ----
        let deleteId = 0;

        function setDeleteId(id) {
            deleteId = id;
        }

        function deleteResult() {
            fetch(`/Result/SoftDelete/${deleteId}`, {
                method: "POST",
                headers: {
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                }
            })
            .then(res => {
                if(res.ok) location.reload();
                else alert("Error deleting record");
            })
            .catch(() => alert("Error deleting record"));
        }
    </script>
}

